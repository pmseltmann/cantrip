{
  "$comment": "Cantrip configuration. Copy this to settings.json and fill in your values. Add as many worker entries as you need (worker-1, worker-2, ..., worker-N). Each worker needs a separate Discord bot application.",

  "discord": {
    "server_id": "YOUR_DISCORD_SERVER_ID",
    "manager_channel_id": "YOUR_MANAGER_CHANNEL_ID",
    "projects_category_id": null
  },

  "user": {
    "discord_user_id": "YOUR_DISCORD_USER_ID",
    "github_username": "YOUR_GITHUB_USERNAME"
  },

  "tokens": {
    "manager": "YOUR_MANAGER_BOT_TOKEN",
    "worker-1": "YOUR_WORKER_1_BOT_TOKEN",
    "worker-2": "YOUR_WORKER_2_BOT_TOKEN",
    "vercel": "YOUR_VERCEL_TOKEN",
    "github": null,
    "replicate": "YOUR_REPLICATE_API_TOKEN"
  },

  "bots": {
    "manager": {
      "discord_user_id": "YOUR_MANAGER_BOT_USER_ID",
      "discord_role_id": null
    },
    "worker-1": {
      "discord_user_id": "YOUR_WORKER_1_BOT_USER_ID",
      "discord_role_id": null
    },
    "worker-2": {
      "discord_user_id": "YOUR_WORKER_2_BOT_USER_ID",
      "discord_role_id": null
    }
  }
}
